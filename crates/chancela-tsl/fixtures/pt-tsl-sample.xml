            <ServiceTypeIdentifier>http://uri.etsi.org/TrstSvc/Svctype/CA/QC</ServiceTypeIdentifier>
            <ServiceName>
              <Name xml:lang="pt">MULTICERT CA para Assinatura Qualificada</Name>
              <Name xml:lang="en">MULTICERT CA para Assinatura Qualificada</Name>
