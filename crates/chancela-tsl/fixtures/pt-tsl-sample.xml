    <SchemeTerritory>PT</SchemeTerritory>
    <ListIssueDateTime>2026-01-15T00:00:00Z</ListIssueDateTime>
    <NextUpdate>
      <dateTime>2026-07-15T00:00:00Z</dateTime>
    </NextUpdate>
  </SchemeInformation>
  <TrustServiceProviderList>

