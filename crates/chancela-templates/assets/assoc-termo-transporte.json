{
  "id": "assoc-termo-transporte/v1",
  "family": "Association",
  "stage": "TermoEncerramento",
  "channels": [],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "assoc-cc/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Termo de transporte do livro de atas" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Órgão", "value": "{{ book.kind }}" },
        { "key": "Livro anterior", "value": "{{ book.predecessor.book_reference }}" },
        { "key": "Data", "value": "{{ closing_date | long_date }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Transporta-se a presente escrituração da associação {{ entity.name }}, NIPC {{ entity.nipc }}, para continuação no livro sucessor, mantendo a continuidade sequencial da numeração das atas e da cadeia de registo."
    },
    { "kind": "Rule" },
    {
      "kind": "SignatureBlock",
      "source": "required_signatories",
      "role": "{{ role }}",
      "name": "{{ name }}"
    }
  ]
}
