{
  "id": "assoc-ata-conselho-fiscal/v1",
  "family": "Association",
  "stage": "Ata",
  "channels": ["Physical", "Hybrid", "Telematic"],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "assoc-cc/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Ata n.º {{ ata_number }}" },
    { "kind": "Heading", "level": 2, "template": "{% if title %}{{ title }}{% else %}Reunião do conselho fiscal{% endif %}" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Sede", "value": "{{ entity.seat }}" },
        { "key": "Data", "value": "{{ meeting_date | long_date }}" },
        { "key": "Hora", "value": "{{ meeting_time }}" },
        { "key": "Local", "value": "{{ place }}" },
        { "key": "Modo de reunião", "value": "{{ channel | channel_label }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "No dia {{ meeting_date | long_date }}, pelas {{ meeting_time }} horas, em {{ place }}, reuniu o conselho fiscal da associação {{ entity.name }}, NIPC {{ entity.nipc }}, no exercício das suas funções de fiscalização, nos termos dos estatutos e do artigo 171.º do Código Civil, para deliberar sobre a ordem de trabalhos abaixo transcrita."
    },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Membros presentes", "value": "{{ members_present }}" },
        { "key": "Referência à lista de presenças", "value": "{{ attendance_reference }}" }
      ]
    },
    { "kind": "Heading", "level": 2, "template": "Ordem de trabalhos" },
    {
      "kind": "Paragraph",
      "items": "agenda",
      "template": "{{ number }}. {{ text }}"
    },
    { "kind": "Heading", "level": 2, "template": "Deliberações e pareceres" },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present }}"
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% for s in statements %}Declaração de voto de {{ s.member }}: {{ s.text }} {% endfor %}"
    },
    {
      "kind": "Paragraph",
      "template": "Nada mais havendo a tratar, foi encerrada a reunião, da qual se lavrou a presente ata que, depois de lida e aprovada, vai ser assinada pelos membros do conselho fiscal presentes."
    },
    { "kind": "Rule" },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
