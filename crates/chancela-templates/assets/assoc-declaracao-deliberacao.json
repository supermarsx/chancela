{
  "id": "assoc-declaracao-deliberacao/v1",
  "family": "Association",
  "stage": "Certidao",
  "channels": [],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "assoc-cc/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Declaração de deliberação" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Sede", "value": "{{ entity.seat }}" },
        { "key": "Ata n.º", "value": "{{ ata_number }}" },
        { "key": "Resumo criptográfico do ato selado", "value": "{{ payload_digest }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Para os devidos efeitos junto de terceiros, declara-se que a assembleia geral da associação {{ entity.name }}, NIPC {{ entity.nipc }}, reunida no dia {{ meeting_date | long_date }}, deliberou o seguinte, conforme consta da ata n.º {{ ata_number }} selada nesta escrituração digital sob o resumo criptográfico (digest) {{ payload_digest }}."
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    { "kind": "Rule" },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
