{
  "id": "condominio-certidao-ata/v1",
  "family": "Condominium",
  "stage": "Certidao",
  "channels": [],
  "signature_policy": "QualifiedOrHandwritten",
  "rule_pack_id": "condominio-dl268/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Certidão de ata" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Condomínio", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Ata n.º", "value": "{{ ata_number }}" },
        { "key": "Livro / órgão", "value": "{{ book.kind }}" },
        { "key": "Digest do ato selado", "value": "{{ payload_digest }}" },
        { "key": "Evento de selagem", "value": "{{ seal_event_seq }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Certifica-se que a presente é cópia fiel e integral da ata n.º {{ ata_number }} da assembleia de condóminos do condomínio {{ entity.name }}, realizada em {{ meeting_date | long_date }} e selada nesta escrituração digital, cujo resumo criptográfico (digest) consta acima."
    },
    { "kind": "Rule" },
    {
      "kind": "Paragraph",
      "template": "No dia {{ meeting_date | long_date }}, pelas {{ meeting_time }} horas, em {{ place }}, reuniu a assembleia de condóminos do condomínio {{ entity.name }}, com {{ members_present }} condóminos presentes e {{ members_represented }} representados, nos termos do artigo 1432.º do Código Civil e do Decreto-Lei n.º 268/94."
    },
    { "kind": "Heading", "level": 2, "template": "Deliberações" },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present + members_represented }}"
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% for s in statements %}Declaração de voto de {{ s.member }}: {{ s.text }} {% endfor %}"
    },
    { "kind": "Rule" },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
