{
  "id": "csc-extrato-ata/v1",
  "family": "CommercialCompany",
  "stage": "Extrato",
  "channels": [],
  "signature_policy": "QualifiedPreferred",
  "rule_pack_id": "csc-art63/v2",
  "locale": "pt-PT",
  "blocks": [
    {
      "kind": "Heading",
      "level": 1,
      "template": "Extrato de ata"
    },
    {
      "kind": "KeyValue",
      "rows": [
        {
          "key": "Entidade",
          "value": "{{ entity.name }}"
        },
        {
          "key": "Ata n.º",
          "value": "{{ ata_number }}"
        },
        {
          "key": "Livro / órgão",
          "value": "{{ book.kind }}"
        },
        {
          "key": "Digest do ato selado",
          "value": "{{ payload_digest }}"
        },
        {
          "key": "Evento de selagem",
          "value": "{{ seal_event_seq }}"
        }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Certifica-se que as deliberações a seguir transcritas constam, em extrato, da ata n.º {{ ata_number }} de {{ entity.name }}, NIPC {{ entity.nipc }}, selada com o digest {{ payload_digest }}."
    },
    {
      "kind": "Rule"
    },
    {
      "kind": "Heading",
      "level": 2,
      "template": "Deliberações"
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present + members_represented }}"
    },
    {
      "kind": "Rule"
    },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
