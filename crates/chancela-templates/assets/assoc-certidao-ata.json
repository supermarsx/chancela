{
  "id": "assoc-certidao-ata/v1",
  "family": "Association",
  "stage": "Certidao",
  "channels": [],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "assoc-cc/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Certidão de ata" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Ata n.º", "value": "{{ ata_number }}" },
        { "key": "Órgão / livro", "value": "{{ book.kind }}" },
        { "key": "Resumo criptográfico do ato selado", "value": "{{ payload_digest }}" },
        { "key": "Evento de selagem", "value": "{{ seal_event_seq }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Certifica-se que a presente constitui reprodução fiel e integral da ata n.º {{ ata_number }} da associação {{ entity.name }}, NIPC {{ entity.nipc }}, selada nesta escrituração digital sob o registo com o resumo criptográfico (digest) {{ payload_digest }}, cujo conteúdo a seguir se reproduz."
    },
    { "kind": "Rule" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Data da reunião", "value": "{{ meeting_date | long_date }}" },
        { "key": "Hora", "value": "{{ meeting_time }}" },
        { "key": "Local", "value": "{{ place }}" },
        { "key": "Presidente da mesa da assembleia geral", "value": "{{ mesa.presidente }}" },
        { "key": "Associados presentes", "value": "{{ members_present }}" },
        { "key": "Associados representados", "value": "{{ members_represented }}" }
      ]
    },
    { "kind": "Heading", "level": 2, "template": "Deliberações" },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present + members_represented }}"
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% for s in statements %}Declaração de voto de {{ s.member }}: {{ s.text }} {% endfor %}"
    },
    { "kind": "Rule" },
    {
      "kind": "Paragraph",
      "template": "A presente certidão é emitida e assinada pelo(s) titular(es) com competência para certificar os atos da associação, conforme abaixo identificado(s)."
    },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
