{
  "id": "cooperativa-ata-ag/v1",
  "family": "Cooperative",
  "stage": "Ata",
  "channels": ["Physical", "Hybrid", "Telematic"],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "cooperativa-ccoop/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Ata n.º {{ ata_number }}" },
    { "kind": "Heading", "level": 2, "template": "{{ title }}" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Sede", "value": "{{ entity.seat }}" },
        { "key": "Data", "value": "{{ meeting_date | long_date }}" },
        { "key": "Hora", "value": "{{ meeting_time }}" },
        { "key": "Local", "value": "{{ place }}" },
        { "key": "Modo de reunião", "value": "{{ channel | channel_label }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "No dia {{ meeting_date | long_date }}, pelas {{ meeting_time }} horas, em {{ place }}, reuniu a assembleia geral de {{ entity.name }}, NIPC {{ entity.nipc }}, cooperativa constituída ao abrigo do Código Cooperativo (Lei n.º 119/2015), para deliberar sobre a ordem de trabalhos abaixo transcrita."
    },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Presidente da mesa", "value": "{{ mesa.presidente }}" },
        { "key": "Secretário(s)", "value": "{{ mesa.secretarios | join(', ') }}" }
      ]
    },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Cooperadores presentes", "value": "{{ members_present }}" },
        { "key": "Cooperadores representados", "value": "{{ members_represented }}" },
        { "key": "Referência à lista de presenças", "value": "{{ attendance_reference }}" }
      ]
    },
    { "kind": "Heading", "level": 2, "template": "Ordem de trabalhos" },
    {
      "kind": "Paragraph",
      "items": "agenda",
      "template": "{{ number }}. {{ text }}"
    },
    { "kind": "Heading", "level": 2, "template": "Deliberações" },
    {
      "kind": "Paragraph",
      "template": "As deliberações constantes desta ata foram tomadas segundo o princípio de um cooperador, um voto, nos termos do artigo 41.º do Código Cooperativo. Os votos a favor, contra e as abstenções indicados correspondem ao número de cooperadores e nunca ao capital subscrito."
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present + members_represented }}"
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% for s in statements %}Declaração de voto de {{ s.member }}: {{ s.text }} {% endfor %}"
    },
    {
      "kind": "KeyValue",
      "items": "referenced_documents",
      "rows": [{ "key": "{{ label }}", "value": "{{ reference }}" }]
    },
    {
      "kind": "Paragraph",
      "template": "Nada mais havendo a tratar, foi encerrada a sessão, da qual se lavrou a presente ata que, depois de lida e aprovada, vai ser assinada."
    },
    { "kind": "Rule" },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
