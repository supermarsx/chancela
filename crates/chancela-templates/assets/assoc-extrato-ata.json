{
  "id": "assoc-extrato-ata/v1",
  "family": "Association",
  "stage": "Extrato",
  "channels": [],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "assoc-cc/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Extrato de ata" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Ata n.º", "value": "{{ ata_number }}" },
        { "key": "Órgão / livro", "value": "{{ book.kind }}" },
        { "key": "Resumo criptográfico do ato selado", "value": "{{ payload_digest }}" },
        { "key": "Evento de selagem", "value": "{{ seal_event_seq }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Certifica-se que as deliberações a seguir transcritas constituem extrato fiel da ata n.º {{ ata_number }} da associação {{ entity.name }}, NIPC {{ entity.nipc }}, reunida em assembleia geral no dia {{ meeting_date | long_date }} e selada nesta escrituração digital sob o registo com o resumo criptográfico (digest) {{ payload_digest }}."
    },
    { "kind": "Heading", "level": 2, "template": "Deliberações extraídas" },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present + members_represented }}"
    },
    { "kind": "Rule" },
    {
      "kind": "Paragraph",
      "template": "O presente extrato é emitido e assinado pelo(s) titular(es) com competência para certificar os atos da associação, conforme abaixo identificado(s)."
    },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
