{
  "id": "fundacao-certidao-ata/v1",
  "family": "Foundation",
  "stage": "Certidao",
  "channels": [],
  "signature_policy": "ManualAttested",
  "rule_pack_id": "fundacao-cc/v1",
  "locale": "pt-PT",
  "blocks": [
    { "kind": "Heading", "level": 1, "template": "Certidão de ata" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Entidade", "value": "{{ entity.name }}" },
        { "key": "NIPC", "value": "{{ entity.nipc }}" },
        { "key": "Ata n.º", "value": "{{ ata_number }}" },
        { "key": "Órgão", "value": "{{ book.kind }}" },
        { "key": "Resumo criptográfico do ato selado", "value": "{{ payload_digest }}" },
        { "key": "Evento de selagem", "value": "{{ seal_event_seq }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "Certifica-se que a presente é cópia fiel e íntegra da ata n.º {{ ata_number }} do órgão da fundação {{ entity.name }}, NIPC {{ entity.nipc }}, selada nesta escrituração digital, cujo resumo criptográfico (digest) do ato selado é {{ payload_digest }}, permitindo verificar a sua integridade."
    },
    { "kind": "Heading", "level": 2, "template": "Teor da ata" },
    {
      "kind": "KeyValue",
      "rows": [
        { "key": "Data", "value": "{{ meeting_date | long_date }}" },
        { "key": "Hora", "value": "{{ meeting_time }}" },
        { "key": "Local", "value": "{{ place }}" },
        { "key": "Modo de reunião", "value": "{{ channel | channel_label }}" }
      ]
    },
    {
      "kind": "Paragraph",
      "template": "No dia {{ meeting_date | long_date }}, pelas {{ meeting_time }} horas, em {{ place }}, reuniu o órgão da fundação {{ entity.name }} para deliberar sobre a ordem de trabalhos que consta do ato selado."
    },
    { "kind": "Heading", "level": 2, "template": "Deliberações" },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}"
    },
    {
      "kind": "VoteTable",
      "items": "deliberation_items",
      "label": "{% if agenda_number %}Ponto {{ agenda_number }} — {% endif %}{{ text }}",
      "vote_field": "vote",
      "unanimous_total": "{{ members_present + members_represented }}"
    },
    {
      "kind": "Paragraph",
      "items": "deliberation_items",
      "template": "{% for s in statements %}Declaração de voto de {{ s.member }}: {{ s.text }} {% endfor %}"
    },
    { "kind": "Rule" },
    {
      "kind": "SignatureBlock",
      "source": "signatories",
      "role": "{{ capacity | role_label }}",
      "name": "{{ name }}"
    }
  ]
}
