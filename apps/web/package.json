{
  "name": "@chancela/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Chancela web shell — Livro de Atas Digital (editorial dark-green/white theme placeholder).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json,html}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "cargo build --release -p chancela-server --locked && npm run build && node e2e/run-playwright-with-cleanup-proof.mjs --project=chromium",
    "test:browser:matrix": "cargo build --release -p chancela-server --locked && npm run build && node e2e/run-playwright-with-cleanup-proof.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-opener": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.3.5",
    "vitest": "^3.0.5"
  }
}
