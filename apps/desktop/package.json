{
  "name": "@chancela/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Chancela desktop app shell (Tauri v2). Intentionally NOT part of the repo-root npm workspaces or Cargo workspace — install and run it from this directory.",
  "scripts": {
    "tauri": "tauri",
    "dev": "npm run dev:plaintext",
    "dev:plaintext": "node -e \"const c=require('child_process');const env={...process.env,CHANCELA_DESKTOP_ALLOW_PLAINTEXT_DB:'1'};const r=c.spawnSync('tauri',['dev'],{stdio:'inherit',shell:process.platform==='win32',env});process.exit(r.status??1)\"",
    "dev:sqlcipher": "tauri dev --features sqlcipher",
    "build": "tauri build --features sqlcipher",
    "build:no-bundle": "tauri build --no-bundle --features sqlcipher",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --locked",
    "test:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/e2e-desktop.ps1",
    "test:smoke:ci": "powershell -NoProfile -ExecutionPolicy Bypass -File ../../scripts/e2e-desktop.ps1 -KillOwnedProcesses"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
